{
  "name": "jsyg-wrapper",
  "version": "2.0.0",
  "description": "jQuery wrapper to work on svg elements",
  "main": "JSYG-wrapper.js",
  "files": ["JSYG-wrapper.js"],
  "scripts": {
    "build-tests": "esbuild tests/tests.js --bundle --format=esm --outfile=tests/tests.min.js",
    "build-examples": "esbuild examples/script.js --bundle --format=esm --outfile=examples/script.min.js",
    "build": "npm run build-tests && npm run build-examples"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/YannickBochatay/JSYG-wrapper.git"
  },
  "keywords": [
    "svg",
    "jquery",
    "javascript",
    "library"
  ],
  "author": "Yannick Bochatay",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/YannickBochatay/JSYG-wrapper/issues"
  },
  "homepage": "https://github.com/YannickBochatay/JSYG-wrapper#readme",
  "dependencies": {
    "jquery": "^3.7.1"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "qunit": "^2.25.0"
  }
}
